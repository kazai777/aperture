# Aperture — environment template. Copy to .env and fill in.
# The real .env is gitignored and must never be committed.

STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

DEPLOYER_ALIAS=aperture-deployer
DEPLOYER_PUBLIC=        # G... public key
DEPLOYER_SECRET=        # S... secret seed (NEVER commit a real one)

VERIFIER_CONTRACT_ID=   # filled in after deploy
